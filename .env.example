# ── LLM 在线 API（至少配置一个，否则自动回退到本地 Ollama） ──
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini
ANTHROPIC_API_KEY=
ANTHROPIC_BASE_URL=https://api.anthropic.com
ANTHROPIC_MODEL=claude-3-5-sonnet-20241022
VISION_PROVIDER=openai

# ── Ollama 本地回退（无 API Key 时自动启用） ──
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5:1.5b

# ── MCP 工具服务 ──
MCP_BASE_URL=http://localhost:3333
MCP_API_KEY=
MCP_PORT_TOOL=port_traffic
MCP_MTR_TOOL=mtr_schedule
MCP_EXCHANGE_TOOL=exchange_rate
MCP_ROUTE_TOOL=route_planner
MCP_FILE_TOOL=file_ops

# ── Google Maps（可选，用于路线规划） ──
GOOGLE_MAPS_API_KEY=

# ── 汇率 / RAG / 超时 ──
EXCHANGE_RATE_API_URL=https://open.er-api.com/v6/latest/HKD
RAG_CORPUS_PATH=./rag_corpus
RAG_DB_PATH=./rag_db
USER_DATA_PATH=./user_data
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
REQUEST_TIMEOUT=15
